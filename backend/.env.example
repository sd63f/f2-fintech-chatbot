# =============================================
# F2 Fintech WhatsApp Bot — Environment Variables
# Copy this file to .env and fill in your values
# =============================================

# ---- Meta Cloud API (WhatsApp) ----
META_ACCESS_TOKEN=your_meta_permanent_access_token_here
META_PHONE_NUMBER_ID=your_phone_number_id_here
META_VERIFY_TOKEN=f2fintech_webhook_verify_2024
META_APP_SECRET=your_meta_app_secret_here

# ---- Google Cloud TTS (Voice) ----
GOOGLE_CLOUD_API_KEY=your_google_cloud_api_key_here
GOOGLE_TTS_LANGUAGE=en-IN
GOOGLE_TTS_VOICE=en-IN-Neural2-A

# ---- Google Gemini AI ----
GEMINI_API_KEY=your_gemini_api_key_here

# ---- Server ----
PORT=3000
NODE_ENV=development
BASE_URL=https://your-cloudflare-tunnel-url.trycloudflare.com

# ---- Feature Flags ----
ENABLE_VOICE=false
ENABLE_AI=true
